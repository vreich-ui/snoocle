# Snoocle server configuration — copy to .env and fill in. NEVER commit .env.

# --- LLM reconciliation (provider is a runtime choice; all three supported) ---
SNOOCLE_LLM_PROVIDER=anthropic          # anthropic | openai | gemini | mock
SNOOCLE_LLM_MODEL=                      # empty = provider default
SNOOCLE_ANTHROPIC_API_KEY=
SNOOCLE_OPENAI_API_KEY=
SNOOCLE_GEMINI_API_KEY=
# Optional: attach a 30s audio snippet to reconciliation for providers that
# support audio input (openai, gemini). Baseline never requires this.
SNOOCLE_LLM_AUDIO_SNIPPET=false

# --- text-source discovery (general web search; no single-site scraper) ------
SNOOCLE_SEARCH_BACKENDS=duckduckgo      # ordered fallback: brave,serpapi,duckduckgo,static
SNOOCLE_BRAVE_API_KEY=
SNOOCLE_SERPAPI_API_KEY=
SNOOCLE_SEARCH_MAX_CANDIDATES=8

# --- storage ------------------------------------------------------------------
SNOOCLE_STORE_DIR=data/songstore        # git-backed versioned artifact store
SNOOCLE_AUDIO_CACHE_DIR=data/audio-cache

# --- heavy MIR engines (optional; librosa fallbacks used when unset) ----------
# Point at checkouts containing a snoocle_runner.py (see mir/chordrec.py docs).
SNOOCLE_CHORD_CNN_LSTM_DIR=
SNOOCLE_SONGFORMER_DIR=

# --- API -----------------------------------------------------------------------
SNOOCLE_HOST=127.0.0.1
SNOOCLE_PORT=8765
