# Snoocle server configuration — copy to .env and fill in. NEVER commit .env.

# --- LLM reconciliation (provider is a runtime choice) ------------------------
SNOOCLE_LLM_PROVIDER=anthropic          # anthropic | openai | gemini | agent | mock
SNOOCLE_LLM_MODEL=                      # empty = provider default
SNOOCLE_ANTHROPIC_API_KEY=
SNOOCLE_OPENAI_API_KEY=
SNOOCLE_GEMINI_API_KEY=

# --- agent-delegated reconciliation (provider "agent") -------------------------
# No LLM keys on Snoocle in this mode: reconciliation is delegated to an
# external agent workspace (Claude Agent SDK) exposing an MCP server. Snoocle
# calls SNOOCLE_AGENT_MCP_TOOL there with {title, artist, mediaUrl,
# timestamped chords, mir, candidates, songSchema} and expects Song JSON back.
SNOOCLE_AGENT_MCP_URL=                  # e.g. https://my-agent.example.run.app/mcp
SNOOCLE_AGENT_MCP_TOOL=reconcile_song
SNOOCLE_AGENT_MCP_AUTH_TOKEN=           # sent as Authorization: Bearer <token>
SNOOCLE_AGENT_MCP_TIMEOUT_SECONDS=600
# Optional: attach a 30s audio snippet to reconciliation for providers that
# support audio input (openai, gemini). Baseline never requires this.
SNOOCLE_LLM_AUDIO_SNIPPET=false

# --- text-source discovery (general web search; no single-site scraper) ------
SNOOCLE_SEARCH_BACKENDS=duckduckgo      # ordered fallback: brave,serpapi,duckduckgo,static
SNOOCLE_BRAVE_API_KEY=
SNOOCLE_SERPAPI_API_KEY=
SNOOCLE_SEARCH_MAX_CANDIDATES=8

# --- storage ------------------------------------------------------------------
# Song persistence backend. "auto" picks Firestore when a GCP project (or the
# Firestore emulator) is configured, else an in-memory store for local/dev/CI.
SNOOCLE_STORE_BACKEND=auto              # auto | firestore | memory
# Firestore (Native mode) is the durable store. Project comes from
# GOOGLE_CLOUD_PROJECT via Application Default Credentials — no key files.
GOOGLE_CLOUD_PROJECT=                   # the PROJECT id, e.g. gen-lang-client-0481163044
# Firestore DATABASE id within that project. Leave as (default) for Firestore's
# default database; set a name to target a NAMED database (e.g. snoocle-db).
# This is NOT the project id.
FIRESTORE_DATABASE=(default)
SNOOCLE_FIRESTORE_COLLECTION=songs
# Point the analysis at the Firestore emulator for local testing:
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
SNOOCLE_AUDIO_CACHE_DIR=data/audio-cache  # disposable audio cache (not the store)

# --- heavy MIR engines (optional; librosa fallbacks used when unset) ----------
# Point at checkouts containing a snoocle_runner.py (see mir/chordrec.py docs).
SNOOCLE_CHORD_CNN_LSTM_DIR=
SNOOCLE_SONGFORMER_DIR=

# --- pipeline reliability (per-step timeouts, seconds) ------------------------
# discover/acquire/mir are best-effort (a timeout is recorded, the run
# continues); reconcile/store are fatal (a timeout -> HTTP 502 naming the step).
# Deploy Cloud Run with --timeout=3600 so it doesn't kill a long real analyze.
SNOOCLE_DISCOVER_TIMEOUT_SECONDS=90
SNOOCLE_ACQUIRE_TIMEOUT_SECONDS=600
SNOOCLE_MIR_TIMEOUT_SECONDS=1500
SNOOCLE_RECONCILE_TIMEOUT_SECONDS=900
SNOOCLE_STORE_TIMEOUT_SECONDS=60

# --- API -----------------------------------------------------------------------
SNOOCLE_HOST=127.0.0.1
SNOOCLE_PORT=8765
# Optional app-level static bearer token. When set, ONE token authorizes both
# the REST API and the /mcp transport — clients send `Authorization: Bearer
# <token>` (/healthz stays exempt). Leave empty to rely on Cloud Run IAM. To use
# it on Cloud Run, deploy the service --allow-unauthenticated and store the token
# in Secret Manager (see docs/DEPLOY_CLOUD_RUN.md). Generate one, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SNOOCLE_API_TOKEN=
